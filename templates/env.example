# =============================================================================
# TEMPLATE DE VARIÁVEIS DE AMBIENTE — EXEMPLO ILUSTRATIVO
# =============================================================================
#
# ⚠️  Este arquivo contém APENAS NOMES DE VARIÁVEIS. Nenhum valor, nenhuma chave,
#     nenhuma credencial — nem de exemplo, nem de teste, nem de produção.
#
# ⚠️  A lista abaixo é ILUSTRATIVA. Não corresponde à configuração real do
#     LodgeFlow, que inclui variáveis diferentes e não é divulgada.
#
# Em produção, nada disto vive em arquivo. Os segredos são injetados pelo
# gerenciador de segredos da plataforma e acessados apenas em tempo de execução.
# Arquivos .env estão no .gitignore desde o primeiro commit.
#
# =============================================================================


# --- Inteligência Artificial -------------------------------------------------
OPENAI_API_KEY=
GEMINI_API_KEY=


# --- Banco de dados ----------------------------------------------------------
DATABASE_URL=
DATABASE_ID=


# --- Autenticação ------------------------------------------------------------
JWT_SECRET=
JWT_ISSUER=
TOKEN_ENCRYPTION_KEY=


# --- OAuth -------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=


# --- Pagamentos --------------------------------------------------------------
STRIPE_KEY=
STRIPE_WEBHOOK_SECRET=
APPLE_IAP_SHARED_SECRET=
GOOGLE_PLAY_SERVICE_ACCOUNT=


# --- Notificações push -------------------------------------------------------
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_PRIVATE_KEY=
FCM_SERVICE_ACCOUNT=


# --- Mensageria --------------------------------------------------------------
TWILIO_TOKEN=
TWILIO_ACCOUNT_SID=
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=


# --- Armazenamento -----------------------------------------------------------
R2_BUCKET_NAME=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=


# --- Aplicação ---------------------------------------------------------------
ENVIRONMENT=
ALLOWED_ORIGINS=
LOG_LEVEL=


# =============================================================================
# BOAS PRÁTICAS
# =============================================================================
#
#  1. Nunca versione um arquivo .env preenchido. Confirme que ele está no
#     .gitignore ANTES do primeiro commit, não depois.
#
#  2. Use o cofre de segredos da plataforma em produção, não arquivos.
#
#  3. Use credenciais distintas por ambiente. Nunca reaproveite chaves de
#     produção em desenvolvimento ou homologação.
#
#  4. Rotacione credenciais periodicamente e imediatamente após qualquer
#     suspeita de exposição.
#
#  5. Nenhum segredo pode entrar no bundle do cliente. Tudo que é embarcado no
#     aplicativo é público, por definição — inclusive o que está "ofuscado".
#
#  6. Se uma chave vazar, revogue primeiro e investigue depois. Remover o commit
#     do histórico NÃO invalida a chave.
#
# =============================================================================
